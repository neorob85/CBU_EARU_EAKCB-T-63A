# =============================================================================
# COMPILE-TIME DEFINES  (baked into the firmware binary)
# These four values are the only ones read by extra/load_env.py.
# =============================================================================

CFG_FIRMWARE_VERSION=1.0.0
CFG_DEVICE_VERSION=2024/03
CFG_DEVICE_MANUFACTURER=Earu
CFG_DEVICE_MODEL=EAKCB-T-M (63 A)

# =============================================================================
# RUNTIME CONFIG  (NOT read at compile time)
# These values are configured at first boot via the provisioning web portal:
#   1. Connect to the open WiFi "EARU_CBU_EAKCB-M-T"
#   2. Navigate to http://10.0.0.1
#   3. Fill in the form and save
#
# After provisioning, navigate to http://<device-ip>:8080 to change them.
# To reset all settings: hold the button for >= 15 s (factory reset).
#
# The lines below are kept as reference only — copy to .env if you want them
# visible, but they have no effect on the build.
# =============================================================================

# CFG_WIFI_SSID=YOUR_WIFI_SSID
# CFG_WIFI_PASSWORD=YOUR_WIFI_PASSWORD
# CFG_MQTT_USER=YOUR_MQTT_USER
# CFG_MQTT_PASS=YOUR_MQTT_PASSWORD
# CFG_MQTT_SERVER=YOUR_MQTT_SERVER_IP
# CFG_MQTT_PORT=1883
# CFG_MQTT_BUFFER_SIZE=2048
# CFG_DASHBOARD_URL=http://YOUR_SERVER_IP:5555
# CFG_DEVICE_NAME=EnergyMeter
# CFG_DEVICE_SN=000000
# CFG_DEVICE_SUGGESTED_AREA=Interrato
# CFG_DEVICE_HA_PREFIX=homeassistant
